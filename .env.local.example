# Copy this file to .env.local and fill in values.
# .env.local is gitignored — never commit your real keys.

# EPA CompTox CCTE API key.
# Request via email to ccte_api@epa.gov (fallback: ccte-api-support@epa.gov).
# Turnaround is usually 1–3 business days.
# Docs: https://api-ccte.epa.gov/docs
EPA_CCTE_API_KEY=

# Optional override of the CCTE base URL (defaults to https://api-ccte.epa.gov)
# EPA_CCTE_BASE_URL=https://api-ccte.epa.gov

# Optional: Gemini key for the LLM extraction layer (used by the next workstream)
# GEMINI_API_KEY=
